---

<section class:list={["company-type-card", `variant-${variant}`]}>
  <span class="company-type-icon" aria-hidden="true">
    <svg
      viewBox="0 0 24 24"
      aria-hidden="true"
      set:html={iconContent[variant]}
    />
  </span>
  <slot />
</section>
