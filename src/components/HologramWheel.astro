---
export interface HologramWheelItem {
  title: string;
  href?: string;
  label?: string;
  type?: string;
  description?: string;
}

interface Props {
  items: HologramWheelItem[];
  idPrefix: string;
  ariaLabel: string;
  centerTitle?: string;
  centerImageSrc?: string;
  centerImageAlt?: string;
  orbitText?: string;
  behavior?: "select" | "link";
  hideActiveLabel?: boolean;
  showCenter?: boolean;
}

const {
  items,
  idPrefix,
  ariaLabel,
  centerTitle = "Mercnet",
  centerImageSrc,
  centerImageAlt = "",
  orbitText = "MERCNET // ROTARY SELECTOR // TARGET LOCK READY //",
  behavior = "select",
  hideActiveLabel = behavior === "select",
  showCenter = true,
} = Astro.props;

const polarPoint = (radius: number, angle: number) => {
  const radians = (angle * Math.PI) / 180;
  return {
    x: 320 + radius * Math.cos(radians),
    y: 320 + radius * Math.sin(radians),
  };
};

const arcPath = (radius: number, centerAngle: number, spread = 20) => {
  const start = polarPoint(radius, centerAngle + spread / 2);
  const end = polarPoint(radius, centerAngle - spread / 2);
  return `M ${start.x.toFixed(2)} ${start.y.toFixed(2)} A ${radius} ${radius} 0 0 0 ${end.x.toFixed(2)} ${end.y.toFixed(2)}`;
};

const wheelStep = 360 / Math.max(items.length, 1);
const wheelItems = items.map((item, index) => {
  const isOuterNode = index % 2 === 0;
  const angle = 90 + index * wheelStep;
  const labelRadius = isOuterNode ? 282 : 244;
  return {
    ...item,
    index,
    angle,
    labelPathId: `${idPrefix}-label-${index}`,
    labelArc: arcPath(labelRadius, angle),
    spoke: isOuterNode
      ? "var(--wheel-spoke-outer)"
      : "var(--wheel-spoke-inner)",
  };
});
---

<div
  class:list={[
    "contract-hologram__display",
    `contract-hologram__display--${behavior}`,
    hideActiveLabel && "contract-hologram__display--hide-active-label",
  ]}
  tabindex={behavior === "select" ? "0" : undefined}
  aria-label={ariaLabel}
>
  <div class="contract-hologram__rings" aria-hidden="true">
    <svg viewBox="0 0 640 640" role="presentation">
      <defs>
        <path
          id={`${idPrefix}-type-path`}
          d="M 144 320 A 176 176 0 1 1 496 320 A 176 176 0 1 1 144 320"></path>
        <filter
          id={`${idPrefix}-glow`}
          x="-20%"
          y="-20%"
          width="140%"
          height="140%"
        >
          <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
          <feMerge>
            <feMergeNode in="blur"></feMergeNode>
            <feMergeNode in="SourceGraphic"></feMergeNode>
          </feMerge>
        </filter>
      </defs>
      <circle
        class="contract-hologram__ring contract-hologram__ring--ghost"
        cx="320"
        cy="320"
        r="238"></circle>
      <circle
        class="contract-hologram__ring contract-hologram__ring--outer"
        cx="320"
        cy="320"
        r="206"></circle>
      <circle
        class="contract-hologram__ring contract-hologram__ring--mid"
        cx="320"
        cy="320"
        r="152"></circle>
      <circle
        class="contract-hologram__ring contract-hologram__ring--core"
        cx="320"
        cy="320"
        r="78"></circle>
      <g class="contract-hologram__ticks">
        {
          // Reduce tick count for performance (was 48)
          Array.from({ length: 16 }).map((_, tick) => (
            <line
              x1="320"
              y1="72"
              x2="320"
              y2={tick % 4 === 0 ? "98" : "86"}
              transform={`rotate(${tick * 22.5} 320 320)`}
            />
          ))
        }
      </g>
      <g class="contract-hologram__arcs" filter={`url(#${idPrefix}-glow)`}>
        {/* Reduce animated arcs for performance */}
        <path d="M 126 320 A 194 194 0 0 1 216 156"></path>
        <path d="M 244 106 A 226 226 0 0 1 472 164"></path>
      </g>
      <g class="contract-hologram__radials">
        <path d="M320 320 L320 92"></path>
        <path d="M320 320 L518 206"></path>
        <path d="M320 320 L516 434"></path>
        <path d="M320 320 L320 548"></path>
        <path d="M320 320 L122 434"></path>
        <path d="M320 320 L122 206"></path>
      </g>
      <text class="contract-hologram__orbit-text">
        <textPath
          href={`#${idPrefix}-type-path`}
          startOffset="50%"
          text-anchor="middle"
        >
          {orbitText}
        </textPath>
      </text>
      {
        showCenter &&
          (centerImageSrc ? (
            <image
              class="contract-hologram__center-image"
              href={centerImageSrc}
              x="268"
              y="284"
              width="104"
              height="72"
              preserveAspectRatio="xMidYMid meet"
              aria-label={centerImageAlt}
            />
          ) : (
            <text
              class="contract-hologram__center-title"
              x="320"
              y="329"
              text-anchor="middle"
            >
              {centerTitle}
            </text>
          ))
      }
      <g class="contract-hologram__reticle">
        <path d="M288 320 H352"></path>
        <path d="M320 288 V352"></path>
        <circle cx="320" cy="320" r="28"></circle>
      </g>
    </svg>
  </div>

  <div
    class="contract-hologram__track"
    style={`--wheel-step: ${wheelStep}deg; --wheel-rotation: 0deg;`}
    aria-label={ariaLabel}
  >
    <svg
      class="contract-hologram__labels"
      viewBox="0 0 640 640"
      role="listbox"
      aria-label={ariaLabel}
    >
      <defs>
        {
          wheelItems.map((item) => (
            <path id={item.labelPathId} d={item.labelArc} />
          ))
        }
      </defs>
      {
        wheelItems.map((item) => {
          const content = (
            <>
              <use
                class="contract-hologram__label-band"
                href={`#${item.labelPathId}`}
              />
              <text class="contract-hologram__label-text">
                <textPath
                  href={`#${item.labelPathId}`}
                  startOffset="50%"
                  text-anchor="middle"
                >
                  {item.title}
                </textPath>
              </text>
            </>
          );

          return behavior === "link" ? (
            <a
              class:list={["contract-hologram__label"]}
              href={item.href ?? "#"}
              aria-label={`${item.label ?? "Open"} ${item.title}`}
              data-hologram-node
            >
              {content}
            </a>
          ) : (
            <g
              class:list={[
                "contract-hologram__label",
                item.index === 0 && "is-active",
              ]}
              role="option"
              tabindex={item.index === 0 ? "0" : "-1"}
              aria-selected={item.index === 0 ? "true" : "false"}
              data-contract-label
              data-contract-node
              data-hologram-node
              data-index={item.index}
              data-title={item.title}
              data-type={item.type ?? item.label ?? "Item"}
              data-description={item.description ?? ""}
              data-href={item.href ?? "#"}
            >
              {content}
            </g>
          );
        })
      }
    </svg>

    <div class="contract-hologram__spokes" aria-hidden="true">
      {
        wheelItems.map((item) => (
          <span
            class:list={[
              "contract-hologram__spoke",
              behavior === "select" && item.index === 0 && "is-active",
            ]}
            style={`--node-angle: ${item.angle}deg; --node-spoke: ${item.spoke};`}
            data-contract-spoke
          />
        ))
      }
    </div>
  </div>
</div>
