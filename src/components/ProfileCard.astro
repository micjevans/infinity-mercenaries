---
type ProfileStat = {
  label: string;
  value: string | number;
  key?: string;
};

type ProfileDetail = {
  title: string;
  value: string | string[];
  wide?: boolean;
  attr?: string;
  list?: boolean;
};

interface ProfileLike {
  id?: string;
  name: string;
  category: string;
  subtitle?: string;
  contracts?: string[];
  troopClass?: string;
  silhouette?: string | number;
  attributes?: Record<string, string | number>;
  baseSkills?: string[];
  weapons?: string[];
  priority?: string[];
  traits?: string[];
  spawn?: string;
  description?: string;
}

interface Props {
  profile?: ProfileLike;
  name?: string;
  category?: string;
  subtitle?: string;
  tags?: string[];
  stats?: ProfileStat[];
  details?: ProfileDetail[];
  interactive?: boolean;
  showTts?: boolean;
}

const {
  profile,
  name = profile?.name ?? "",
  category = profile?.category ?? "Profile",
  subtitle = profile?.subtitle,
  tags = [...(profile?.contracts ?? []), ...(profile?.troopClass ? [profile.troopClass] : [])],
  interactive = false,
  showTts = false
} = Astro.props;

const profileStats: ProfileStat[] =
  Astro.props.stats ??
  (profile
    ? [
        { label: "MOV", value: profile.attributes?.mov ?? "-", key: "mov" },
        { label: "CC", value: profile.attributes?.cc ?? "-", key: "cc" },
        { label: "BS", value: profile.attributes?.bs ?? "-", key: "bs" },
        { label: "PH", value: profile.attributes?.ph ?? "-", key: "ph" },
        { label: "WIP", value: profile.attributes?.wip ?? "-", key: "wip" },
        { label: "ARM", value: profile.attributes?.arm ?? "-", key: "arm" },
        { label: "BTS", value: profile.attributes?.bts ?? "-", key: "bts" },
        { label: "W", value: profile.attributes?.vita ?? "-", key: "vita" },
        { label: "S", value: profile.silhouette ?? "-" }
      ]
    : []);

const profileDetails: ProfileDetail[] =
  Astro.props.details ??
  (profile
    ? [
        { title: "Skills", value: profile.baseSkills ?? [], attr: "data-npc-skills" },
        { title: "Weapons", value: profile.weapons ?? [] },
        { title: "Priority", value: profile.priority ?? [] },
        { title: "Traits", value: profile.traits ?? [] },
        ...(profile.spawn ? [{ title: "Spawn", value: profile.spawn, wide: true }] : []),
        ...(profile.description ? [{ title: "Description", value: profile.description, wide: true }] : [])
      ]
    : []);

const profileAttrs =
  interactive && profile
    ? {
        "data-npc-profile": profile.id,
        "data-npc-profile-json": JSON.stringify(profile)
      }
    : {};

const renderValue = (value: string | string[], separator = ", ") =>
  Array.isArray(value) ? value.join(separator) : value;
---

<article class="npc-profile-card" {...profileAttrs}>
  <header>
    <div>
      <span>{category}</span>
      <h3>{name}</h3>
      {subtitle && <p>{subtitle}</p>}
    </div>
    {tags.length > 0 && (
      <div class="npc-tags">
        {tags.map((tag) => <span>{tag}</span>)}
      </div>
    )}
  </header>

  <dl class="npc-stat-grid" style={`--stat-count: ${profileStats.length}`}>
    {profileStats.map((stat) => (
      <div>
        <dt>{stat.label}</dt>
        <dd {...(stat.key ? { "data-npc-stat": stat.key } : {})}>{stat.value}</dd>
      </div>
    ))}
  </dl>

  {profileDetails.length > 0 && (
    <div class="npc-detail-grid">
      {profileDetails.map((detail) => (
        <section class:list={[detail.wide && "wide"]}>
          <h4>{detail.title}</h4>
          {detail.list && Array.isArray(detail.value) ? (
            <ul>
              {detail.value.map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <p {...(detail.attr ? { [detail.attr]: "" } : {})}>
              {renderValue(detail.value, detail.title === "Priority" ? " > " : ", ")}
            </p>
          )}
        </section>
      ))}
    </div>
  )}

  {showTts && (
    <section class="npc-tts-panel">
      <div class="npc-tts-bar">
        <div class="npc-tts-actions">
          <button type="button" data-copy-tts="name">Copy Name</button>
          <button type="button" data-copy-tts="profile">Copy Profile</button>
        </div>
        <p data-copy-status aria-live="polite"></p>
      </div>
      <details class="npc-tts-details">
        <summary>Show formatted text</summary>
        <pre data-npc-tts-preview></pre>
      </details>
    </section>
  )}
</article>
