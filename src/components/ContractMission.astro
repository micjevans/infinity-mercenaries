---
import DeploymentMap from "./DeploymentMap.astro";
import ObjectiveList from "./ObjectiveList.astro";
import TwistTable from "./TwistTable.astro";

type Objective = {
  points: string;
  text: string;
};

type TwistRow = {
  roll: string;
  name: string;
  effect: string;
};

type EndCondition = {
  title?: string;
  text: string;
};

interface Props {
  objectives: Objective[];
  deployment: Record<string, unknown>;
  twistTitle: string;
  twistIntro: string;
  twistRows: TwistRow[];
  endConditions: EndCondition[];
}

const {
  objectives,
  deployment,
  twistTitle,
  twistIntro,
  twistRows,
  endConditions
} = Astro.props;

const hasNpcs = Astro.slots.has("npcs");
---

<section class="contract-section">
  <h2>Mission Objectives</h2>
  <ObjectiveList objectives={objectives} />
</section>

<section class="contract-section">
  <h2>Forces and Deployment</h2>
  <slot name="forces" />
  <DeploymentMap {...deployment} />
</section>

<section class="contract-section">
  <h2>Scenario Special Rules</h2>
  <slot name="specialRules" />
</section>

{hasNpcs && (
  <section class="contract-section">
    <h2>NPC Profiles</h2>
    <slot name="npcs" />
  </section>
)}

<section class="contract-section">
  <h2>Twist</h2>
  <p>{twistIntro}</p>
  <TwistTable title={twistTitle} rows={twistRows} />
</section>

<section class="contract-section">
  <h2>End of Mission</h2>
  <aside class="end-mission-card">
    <header>
      <span>End State</span>
      <strong>Mission End Conditions</strong>
    </header>
    <div class="end-condition-list">
      {endConditions.map((condition) => (
        <article>
          {condition.title && <h3>{condition.title}</h3>}
          <p>{condition.text}</p>
        </article>
      ))}
    </div>
  </aside>
</section>
