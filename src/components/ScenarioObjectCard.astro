---
type Stat = {
  label: string;
  value: string;
};

interface Props {
  eyebrow?: string;
  title: string;
  stats: Stat[];
}

const { eyebrow = "Scenario Object", title, stats } = Astro.props;
---

<aside class="scenario-object-card">
  <header>
    <div>
      <span>{eyebrow}</span>
      <strong>{title}</strong>
    </div>
  </header>
  <div class="object-stats">
    {stats.map((stat) => (
      <div>
        <span>{stat.label}</span>
        <strong>{stat.value}</strong>
      </div>
    ))}
  </div>
  <div class="object-body">
    <slot />
  </div>
</aside>
