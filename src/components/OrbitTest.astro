---
import { buildOrbitScene, type OrbitMenu } from "../lib/orbitTest";

type Props = {
  menu: OrbitMenu;
};

const { menu } = Astro.props as Props;
const collapsedScene = buildOrbitScene(menu, { includeSubmenu: false });
const expandedScene = buildOrbitScene(menu, { includeSubmenu: true });
const contractsSubmenuScene = buildOrbitScene(menu, {
  includeSubmenu: true,
  targetMenuGroup: "contracts",
});
const rulesSubmenuScene = buildOrbitScene(menu, {
  includeSubmenu: true,
  targetMenuGroup: "rules",
});

const collapsedOrbitRingMeta = collapsedScene.orbitRingMeta;
const collapsedGravitySpotSize = collapsedScene.gravitySpotSize;
const expandedGravitySpotSize = expandedScene.gravitySpotSize;
const contractsGravitySpotSize = contractsSubmenuScene.gravitySpotSize;
const rulesGravitySpotSize = rulesSubmenuScene.gravitySpotSize;

// Extract submenu data for both templates
const contractsSubmenuMeta = contractsSubmenuScene.orbitRingMeta.filter(
  (orbit) => orbit.isSubmenu || orbit.isFiller,
);
const rulesSubmenuMeta = rulesSubmenuScene.orbitRingMeta.filter(
  (orbit) => orbit.isSubmenu || orbit.isFiller,
);
---

<div
  class="bigbang"
  style={`width: min(100%, ${collapsedGravitySpotSize}px);`}
  data-collapsed-size={collapsedGravitySpotSize}
  data-expanded-size={expandedGravitySpotSize}
  data-contracts-size={contractsGravitySpotSize}
  data-rules-size={rulesGravitySpotSize}
>
  <div
    class="gravity-spot"
    style={`width: ${collapsedGravitySpotSize}px; height: ${collapsedGravitySpotSize}px;`}
    data-collapsed-size={collapsedGravitySpotSize}
    data-expanded-size={expandedGravitySpotSize}
    data-submenu-mounted="false"
  >
    <div class="orbit-0">
      <div class="satellite at-center">M</div>
    </div>

    {
      collapsedOrbitRingMeta.map((orbit) => (
        <div
          data-menu-group={orbit.menuGroup || undefined}
          class={`orbit-${orbit.orbitNumber} ${orbit.isFiller ? `${orbit.rangeClass} filler` : "range-360"} ${orbit.rotationDirection === "reverse" ? "reverse" : ""} labels${orbit.isTopMenu || orbit.isTitleOrbit ? "" : orbit.menuGroup === "contracts" ? " contracts" : ""} ${orbit.isPairedMenu ? "paired-menu" : ""} ${orbit.isTitleOrbit ? "title-orbit" : ""} ${orbit.isSubmenu ? "submenu-orbit" : ""}`}
          style={`--o-size-ratio: ${orbit.sizeRatio}; --o-force-ratio: 1; --o-fixed-font-size: ${orbit.fontSize}rem; --o-from: ${orbit.from}; --o-gap: ${orbit.gap};`}
        >
          {orbit.contracts.map((label, index) => (
            <o-arc
              class={
                orbit.isFiller
                  ? `filler-arc ${typeof label === "object" && label.angleClass ? label.angleClass : orbit.angleClass} ${typeof label === "object" && label.sizeRatioClass ? label.sizeRatioClass : ""} ${typeof label === "object" && label.gapClass ? label.gapClass : "gap-10"}`
                  : orbit.isTitleOrbit
                    ? "title-arc"
                    : `button-arc control-${(index % 5) + 1} gap-${orbit.isTopMenu ? 12 : 10}`
              }
              text-anchor={orbit.isTitleOrbit ? "start" : "middle"}
              style="dominant-baseline: middle;"
            >
              {orbit.isFiller ? null : label}
            </o-arc>
          ))}
        </div>
      ))
    }
  </div>

  <template id="submenu-rings-template-contracts">
    {
      contractsSubmenuMeta.map((orbit) => (
        <div
          data-submenu-ring="true"
          data-menu-group={orbit.menuGroup || undefined}
          class={`orbit-${orbit.orbitNumber} ${orbit.isFiller ? `${orbit.rangeClass} filler` : "range-360"} ${orbit.rotationDirection === "reverse" ? "reverse" : ""} labels${orbit.isTopMenu || orbit.isTitleOrbit ? "" : orbit.menuGroup === "contracts" ? " contracts" : ""} ${orbit.isPairedMenu ? "paired-menu" : ""} ${orbit.isTitleOrbit ? "title-orbit" : ""} ${orbit.isSubmenu ? "submenu-orbit" : ""}`}
          style={`--o-size-ratio: ${orbit.sizeRatio}; --o-force-ratio: 1; --o-fixed-font-size: ${orbit.fontSize}rem; --o-from: ${orbit.from}; --o-gap: ${orbit.gap};`}
        >
          {orbit.contracts.map((label, index) => (
            <o-arc
              class={
                orbit.isFiller
                  ? `filler-arc ${typeof label === "object" && label.angleClass ? label.angleClass : orbit.angleClass} ${typeof label === "object" && label.sizeRatioClass ? label.sizeRatioClass : ""} ${typeof label === "object" && label.gapClass ? label.gapClass : "gap-10"}`
                  : orbit.isTitleOrbit
                    ? "title-arc"
                    : `button-arc control-${(index % 5) + 1} gap-${orbit.isTopMenu ? 12 : 10}`
              }
              text-anchor={orbit.isTitleOrbit ? "start" : "middle"}
              style="dominant-baseline: middle;"
            >
              {orbit.isFiller ? null : label}
            </o-arc>
          ))}
        </div>
      ))
    }
  </template>

  <template id="submenu-rings-template-rules">
    {
      rulesSubmenuMeta.map((orbit) => (
        <div
          data-submenu-ring="true"
          data-menu-group={orbit.menuGroup || undefined}
          class={`orbit-${orbit.orbitNumber} ${orbit.isFiller ? `${orbit.rangeClass} filler` : "range-360"} ${orbit.rotationDirection === "reverse" ? "reverse" : ""} labels${orbit.isTopMenu || orbit.isTitleOrbit ? "" : orbit.menuGroup === "rules" ? " rules" : ""} ${orbit.isPairedMenu ? "paired-menu" : ""} ${orbit.isTitleOrbit ? "title-orbit" : ""} ${orbit.isSubmenu ? "submenu-orbit" : ""}`}
          style={`--o-size-ratio: ${orbit.sizeRatio}; --o-force-ratio: 1; --o-fixed-font-size: ${orbit.fontSize}rem; --o-from: ${orbit.from}; --o-gap: ${orbit.gap};`}
        >
          {orbit.contracts.map((label, index) => (
            <o-arc
              class={
                orbit.isFiller
                  ? `filler-arc ${typeof label === "object" && label.angleClass ? label.angleClass : orbit.angleClass} ${typeof label === "object" && label.sizeRatioClass ? label.sizeRatioClass : ""} ${typeof label === "object" && label.gapClass ? label.gapClass : "gap-10"}`
                  : orbit.isTitleOrbit
                    ? "title-arc"
                    : `button-arc control-${(index % 5) + 1} gap-${orbit.isTopMenu ? 12 : 10}`
              }
              text-anchor={orbit.isTitleOrbit ? "start" : "middle"}
              style="dominant-baseline: middle;"
            >
              {orbit.isFiller ? null : label}
            </o-arc>
          ))}
        </div>
      ))
    }
  </template>
</div>

<script>
  const getNumericDegrees = (value) => parseFloat(value) || 0;

  const normalizeAngle = (value) => ((value % 360) + 360) % 360;

  const shortestAngleDelta = (from, to) => {
    const delta = to - from;
    return ((delta + 180) % 360) - 180;
  };

  function updateFlipForOrbit(orbitContainer) {
    if (!orbitContainer) return;

    const orbitFrom = getNumericDegrees(
      getComputedStyle(orbitContainer).getPropertyValue("--o-from"),
    );

    let stackAngle = 0;
    const arcs = Array.from(orbitContainer.querySelectorAll("o-arc"));
    arcs.forEach((arc) => {
      if (arc.classList.contains("title-arc")) {
        arc.removeAttribute("flip");
        return;
      }

      const rawAngle = getComputedStyle(arc).getPropertyValue("--o-angle");
      const arcAngle = arc.calcularExpresionCSS
        ? arc.calcularExpresionCSS(rawAngle)
        : parseFloat(rawAngle) || 0;

      const centerAngle = normalizeAngle(orbitFrom + stackAngle + arcAngle / 2);
      const isBottomHalf = centerAngle >= 90 && centerAngle <= 270;

      if (isBottomHalf) {
        arc.setAttribute("flip", "");
      } else {
        arc.removeAttribute("flip");
      }

      stackAngle += arcAngle;
    });
  }

  function isArcHitByPoint(arc, x, y) {
    const svg = arc.shadowRoot?.querySelector("svg");
    const shape = arc.shadowRoot?.querySelector("#orbitShape");
    if (!svg || !shape || !svg.getScreenCTM) return false;

    const screenCTM = svg.getScreenCTM();
    if (!screenCTM) return false;

    const point = svg.createSVGPoint();
    if (!point) return false;
    point.x = x;
    point.y = y;
    const localPoint = point.matrixTransform(screenCTM.inverse());
    return shape.isPointInFill(localPoint) || shape.isPointInStroke(localPoint);
  }

  function findHitArc(x, y) {
    const arcs = Array.from(document.querySelectorAll("o-arc.button-arc"));
    let hitArc = null;
    let hitOrbitNumber = -Infinity;

    arcs.forEach((arc) => {
      if (!isArcHitByPoint(arc, x, y)) return;

      const orbit = arc.closest(".range-360.labels");
      if (!orbit) return;
      const orbitNumber = parseFloat(
        getComputedStyle(orbit).getPropertyValue("--o-orbit-number") || "0",
      );

      if (orbitNumber >= hitOrbitNumber) {
        hitOrbitNumber = orbitNumber;
        hitArc = arc;
      }
    });

    return hitArc;
  }

  function applyOrbitDelta(orbitContainer, delta) {
    const currentFrom = normalizeAngle(
      getNumericDegrees(
        getComputedStyle(orbitContainer).getPropertyValue("--o-from"),
      ),
    );
    const nextFrom = normalizeAngle(currentFrom + delta);
    orbitContainer.style.setProperty("--o-from", `${nextFrom}deg`);
    return nextFrom;
  }

  function calculateOrbitRotationDelta(orbitContainer, arc) {
    const orbitStyle = getComputedStyle(orbitContainer);
    const currentFrom = normalizeAngle(
      getNumericDegrees(orbitStyle.getPropertyValue("--o-from")),
    );

    let stackAngle = 0;
    const arcs = Array.from(orbitContainer.querySelectorAll("o-arc"));
    for (const currentArc of arcs) {
      if (currentArc === arc) break;
      const rawAngle =
        getComputedStyle(currentArc).getPropertyValue("--o-angle");
      const arcAngle = currentArc.calcularExpresionCSS
        ? currentArc.calcularExpresionCSS(rawAngle)
        : parseFloat(rawAngle) || 0;
      stackAngle += arcAngle;
    }

    const rawAngle = getComputedStyle(arc).getPropertyValue("--o-angle");
    const arcAngle = arc.calcularExpresionCSS
      ? arc.calcularExpresionCSS(rawAngle)
      : parseFloat(rawAngle) || 0;

    const arcCenter = normalizeAngle(currentFrom + stackAngle + arcAngle / 2);
    const delta = shortestAngleDelta(arcCenter, 180);
    const nextFrom = normalizeAngle(currentFrom + delta);

    return {
      delta,
      orbitNumber: parseFloat(
        orbitStyle.getPropertyValue("--o-orbit-number") || "0",
      ),
    };
  }

  function rotateOrbitGroupToArc(orbitContainer, arc) {
    const { delta } = calculateOrbitRotationDelta(orbitContainer, arc);
    const menuGroup = orbitContainer.dataset.menuGroup;
    const orbitContainers = menuGroup
      ? Array.from(
          document.querySelectorAll(`[data-menu-group="${menuGroup}"]`),
        )
      : [orbitContainer];

    orbitContainers.forEach((orbit) => applyOrbitDelta(orbit, delta));
    requestAnimationFrame(() => {
      orbitContainers.forEach(updateFlipForOrbit);
      setTimeout(() => orbitContainers.forEach(updateFlipForOrbit), 420);
    });
  }

  // --- Performance: Hover throttling and caching ---
  let lastHoveredArc = null;
  let hoverRAF = null;
  let pendingHover = null;

  function clearArcHover() {
    if (lastHoveredArc) {
      lastHoveredArc.classList.remove("hovered");
      lastHoveredArc = null;
    }
  }

  function updateArcHoverThrottled(x, y) {
    // Only schedule one per frame
    pendingHover = { x, y };
    if (hoverRAF) return;
    hoverRAF = requestAnimationFrame(() => {
      hoverRAF = null;
      const { x, y } = pendingHover;
      pendingHover = null;
      // Cache arcs for this frame
      const arcs = Array.from(document.querySelectorAll("o-arc.button-arc"));
      let hitArc = null;
      let hitOrbitNumber = -Infinity;
      for (const arc of arcs) {
        if (!isArcHitByPoint(arc, x, y)) continue;
        const orbit = arc.closest(".range-360.labels");
        if (!orbit) continue;
        const orbitNumber = parseFloat(
          getComputedStyle(orbit).getPropertyValue("--o-orbit-number") || "0",
        );
        if (orbitNumber >= hitOrbitNumber) {
          hitOrbitNumber = orbitNumber;
          hitArc = arc;
        }
      }
      if (hitArc !== lastHoveredArc) {
        if (lastHoveredArc) lastHoveredArc.classList.remove("hovered");
        if (hitArc) hitArc.classList.add("hovered");
        lastHoveredArc = hitArc;
      }
    });
  }

  window.addEventListener("load", () => {
    const bigbang = document.querySelector(".bigbang");
    const gravitySpot = document.querySelector(".gravity-spot");
    // Multiple submenu templates for rules and contracts
    const submenuTemplates = {
      rules: document.querySelector("#submenu-rings-template-rules"),
      contracts: document.querySelector("#submenu-rings-template-contracts"),
    };
    if (!bigbang || !gravitySpot) return;

    const collapsedSize = Number(gravitySpot.dataset.collapsedSize || "560");
    const expandedSize = Number(gravitySpot.dataset.expandedSize || "560");
    const contractsSize = Number(bigbang.dataset.contractsSize || expandedSize);
    const rulesSize = Number(bigbang.dataset.rulesSize || expandedSize);

    const setGravitySize = (size) => {
      const viewportWidth = window.visualViewport?.width ?? window.innerWidth;
      const viewportHeight =
        window.visualViewport?.height ?? window.innerHeight;

      // Keep extra room for text overhang and mobile browser chrome.
      const edgePadding = 0;
      const labelOverhangFactor = 1;
      const availableViewportSize = Math.min(
        viewportWidth - edgePadding,
        viewportHeight - edgePadding,
      );
      const availableSize = Math.max(200, availableViewportSize);
      const requiredSize = size * labelOverhangFactor;
      const scale = Math.min(1, availableSize / requiredSize);
      const visualSize = Math.max(200, Math.floor(size * scale));

      bigbang.style.width = `${visualSize}px`;
      bigbang.style.maxWidth = "100%";

      gravitySpot.style.width = `${size}px`;
      gravitySpot.style.height = `${size}px`;
      gravitySpot.style.transform = `scale(${scale})`;
    };

    // --- Performance: Batch filler animation loop ---
    let fillerAnimationFrame = null;
    function startFillerAnimations() {
      const fillers = Array.from(document.querySelectorAll(".filler"));
      fillers.forEach((orbit) => {
        if (orbit.dataset.fillerAnimated === "true") return;
        orbit.dataset.fillerAnimated = "true";
        orbit._fillerAngle = Math.random() * 360;
        orbit._fillerSpeed = Math.random() * 0.12 + 0.04; // deg/ms
      });
      if (fillerAnimationFrame) cancelAnimationFrame(fillerAnimationFrame);
      function animateFillers(ts) {
        fillers.forEach((orbit) => {
          if (!document.body.contains(orbit)) return;
          orbit._fillerAngle =
            (orbit._fillerAngle + orbit._fillerSpeed * 16) % 360;
          orbit.style.transform = `rotate(${orbit._fillerAngle}deg)`;
        });
        fillerAnimationFrame = requestAnimationFrame(animateFillers);
      }
      fillerAnimationFrame = requestAnimationFrame(animateFillers);
    }

    // --- Performance: Batch title orbit animation loop ---
    let titleOrbitAnimationFrame = null;
    function startTitleOrbitAnimations() {
      const titleOrbits = Array.from(document.querySelectorAll(".title-orbit"));
      titleOrbits.forEach((orbit) => {
        if (orbit.dataset.titleOrbitAnimated === "true") return;
        orbit.dataset.titleOrbitAnimated = "true";
        orbit._titleAngle = getNumericDegrees(
          getComputedStyle(orbit).getPropertyValue("--o-from"),
        );
      });
      if (titleOrbitAnimationFrame)
        cancelAnimationFrame(titleOrbitAnimationFrame);
      let lastTimestamp = null;
      function animateTitleOrbits(ts) {
        if (lastTimestamp === null) lastTimestamp = ts;
        const delta = (ts - lastTimestamp) / 1000;
        lastTimestamp = ts;
        titleOrbits.forEach((orbit) => {
          if (!document.body.contains(orbit)) return;
          orbit._titleAngle = normalizeAngle(orbit._titleAngle + delta * 4);
          orbit.style.setProperty("--o-from", `${orbit._titleAngle}deg`);
          updateFlipForOrbit(orbit);
        });
        titleOrbitAnimationFrame = requestAnimationFrame(animateTitleOrbits);
      }
      titleOrbitAnimationFrame = requestAnimationFrame(animateTitleOrbits);
    }

    const refreshOrbitFlips = () => {
      requestAnimationFrame(() => {
        Array.from(document.querySelectorAll(".range-360.labels")).forEach(
          (orbit) => {
            updateFlipForOrbit(orbit);
          },
        );
      });
    };

    let mountedSubmenuType = null;
    const mountSubmenu = (type) => {
      if (
        gravitySpot.dataset.submenuMounted === "true" &&
        mountedSubmenuType === type
      )
        return;
      unmountSubmenu();
      const template = submenuTemplates[type];
      if (!template) return;
      const fragment = template.content.cloneNode(true);
      gravitySpot.appendChild(fragment);
      gravitySpot.dataset.submenuMounted = "true";
      mountedSubmenuType = type;
      const sizeForType = type === "contracts" ? contractsSize : rulesSize;
      setGravitySize(sizeForType);
      refreshOrbitFlips();
      startFillerAnimations();
      startTitleOrbitAnimations();
    };

    const unmountSubmenu = () => {
      if (gravitySpot.dataset.submenuMounted !== "true") return;
      Array.from(
        gravitySpot.querySelectorAll('[data-submenu-ring="true"]'),
      ).forEach((ring) => ring.remove());
      gravitySpot.dataset.submenuMounted = "false";
      mountedSubmenuType = null;
      setGravitySize(collapsedSize);
      refreshOrbitFlips();
      clearArcHover();
    };

    setGravitySize(collapsedSize);
    refreshOrbitFlips();
    startFillerAnimations();
    startTitleOrbitAnimations();

    window.addEventListener("resize", () => {
      if (gravitySpot.dataset.submenuMounted === "true") {
        const activeSize =
          mountedSubmenuType === "contracts" ? contractsSize : rulesSize;
        setGravitySize(activeSize);
      } else {
        setGravitySize(collapsedSize);
      }
    });

    // --- Performance: Prevent duplicate listeners ---
    if (!gravitySpot._listenersAdded) {
      gravitySpot.addEventListener("pointermove", (event) => {
        updateArcHoverThrottled(event.clientX, event.clientY);
      });
      gravitySpot.addEventListener("pointerleave", clearArcHover);
      gravitySpot.addEventListener("click", (event) => {
        const hitArc =
          lastHoveredArc ?? findHitArc(event.clientX, event.clientY);
        if (!hitArc) return;

        const orbit = hitArc.closest(".range-360.labels");
        if (!orbit) return;

        rotateOrbitGroupToArc(orbit, hitArc);

        // Keep submenu behavior in sync after rotating top navigation items.
        if (orbit.dataset.menuGroup === "navigation") {
          const label = hitArc.textContent?.trim().toLowerCase();
          if (label === "contracts") {
            mountSubmenu("contracts");
          } else if (label === "rules") {
            mountSubmenu("rules");
          } else {
            unmountSubmenu();
          }
        }
      });
      gravitySpot._listenersAdded = true;
    }
  });
</script>

<style>
  .bigbang {
    width: min(100%, 560px);
    min-height: 100vh;
    margin: 0 auto;
    padding: 1.5rem;
    display: grid;
    place-items: center;
    box-sizing: border-box;
  }

  .gravity-spot {
    position: relative;
    width: min(100%, 560px);
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    border-radius: 50%;
    overflow: visible;
    transform-origin: center;
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .gravity-spot::before,
  .gravity-spot::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    pointer-events: none;
  }

  .gravity-spot::before {
    background: none;
  }

  .gravity-spot::after {
    background: none;
    mix-blend-mode: screen;
  }

  .satellite.at-center {
    width: 5.6rem;
    height: 5.6rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: radial-gradient(
      circle at 25% 20%,
      rgba(71, 221, 228, 0.16),
      rgba(8, 18, 26, 0.92)
    );
    color: #9efff1;
    text-shadow: 0 0 0.45rem rgba(158, 255, 241, 0.55);
    font-weight: 700;
    box-shadow: inset 0 0 0 1px rgba(71, 221, 228, 0.16);
  }

  .satellite.at-center img {
    width: 60%;
    height: auto;
    display: block;
  }

  o-arc {
    --o-fill: rgba(35, 169, 183, 0.14);
    --o-stroke: rgba(71, 221, 228, 0.92);
    --o-stroke-width: 0.72;
    color: #9efff1;
    font-family: "Orbitron", "Exo 2", ui-sans-serif, system-ui, sans-serif;
    text-shadow: 0 0 0.35rem rgba(158, 255, 241, 0.32);
    cursor: pointer;
    pointer-events: none;
    transition:
      transform 420ms cubic-bezier(0.77, 0, 0.18, 1),
      --o-fill 120ms ease,
      --o-stroke 120ms ease;
    filter: drop-shadow(0 0 16px rgba(71, 221, 228, 0.26))
      drop-shadow(0 0 28px rgba(71, 221, 228, 0.18));
  }

  o-arc.button-arc {
    /* Remove filter transition for instant hover */
    transition:
      transform 420ms cubic-bezier(0.77, 0, 0.18, 1),
      --o-fill 80ms ease,
      --o-stroke 80ms ease;
    --o-fill: rgba(35, 169, 183, 0.18);
    --o-stroke: rgba(114, 255, 255, 0.96);
    --o-stroke-width: 0.74;
    /* Performance: reduce to one strong glow */
    filter: drop-shadow(0 0 12px rgba(114, 255, 255, 0.38));
  }

  .filler {
    transform-origin: center center;
    transition: transform var(--filler-duration, 1s) ease;
    pointer-events: none;
  }

  .filler-arc {
    --o-fill: rgba(var(--o-yellow-light-rgb, 214, 255, 63), 0.18);
    --o-stroke: rgba(var(--o-yellow-rgb, 214, 255, 63), 1);
    --o-stroke-width: 0.52;
    opacity: 0.96;
    filter: drop-shadow(0 0 14px rgba(214, 255, 63, 0.54))
      drop-shadow(0 0 28px rgba(214, 255, 63, 0.36))
      drop-shadow(0 0 40px rgba(214, 255, 63, 0.22));
  }

  .filler-arc.thin {
    --o-stroke-width: 0.36;
    opacity: 0.84;
    filter: drop-shadow(0 0 11px rgba(214, 255, 63, 0.38))
      drop-shadow(0 0 20px rgba(214, 255, 63, 0.26));
  }

  .filler-arc.medium {
    --o-stroke-width: 0.58;
    opacity: 0.92;
    filter: drop-shadow(0 0 14px rgba(214, 255, 63, 0.44))
      drop-shadow(0 0 24px rgba(214, 255, 63, 0.3));
  }

  .filler-arc.thick {
    --o-stroke-width: 0.86;
    opacity: 1;
    filter: drop-shadow(0 0 20px rgba(214, 255, 63, 0.6))
      drop-shadow(0 0 34px rgba(214, 255, 63, 0.4));
  }

  o-arc {
    stroke-linecap: round;
    mix-blend-mode: screen;
  }

  o-arc.button-arc.hovered {
    --o-fill: rgba(71, 221, 228, 0.28);
    --o-stroke: rgba(164, 255, 255, 1);
    --o-stroke-width: 0.86;
    /* Performance: single, brighter glow */
    filter: drop-shadow(0 0 18px rgba(114, 255, 255, 0.44));
  }

  .contracts {
    z-index: var(--o-orbit-number);
    filter: drop-shadow(0 0 14px rgba(67, 215, 252, 0.12));
  }

  .orbit-0,
  .orbit-4,
  .orbit-5,
  .orbit-8,
  .orbit-12 {
    filter: drop-shadow(0 0 16px rgba(43, 206, 255, 0.1));
  }

  .paired-menu o-arc.button-arc {
    --o-fill: rgba(214, 255, 63, 0.08);
    --o-stroke: rgba(214, 255, 63, 0.95);
    filter: drop-shadow(0 0 14px rgba(214, 255, 63, 0.28));
  }

  .title-arc {
    --o-fill: transparent;
    --o-stroke: transparent;
    color: rgba(214, 255, 63, 0.95);
    text-shadow: 0 0 0.2rem rgba(214, 255, 63, 0.55);
  }

  @media (max-width: 768px) {
    .bigbang {
      padding: 0.5rem;
      min-height: 100svh;
    }
  }
</style>
