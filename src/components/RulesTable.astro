---
type TableRow = {
  label: string;
  cells: Array<string | number>;
};

interface Props {
  eyebrow?: string;
  title: string;
  columns: string[];
  rows: TableRow[];
  note?: string;
  variant?: "matrix" | "text";
}

const { eyebrow = "Reference", title, columns, rows, note, variant = "matrix" } = Astro.props;
---

<section class:list={["rules-table-card", `variant-${variant}`]}>
  <header>
    <span>{eyebrow}</span>
    <strong>{title}</strong>
  </header>
  <div class="rules-table-wrap">
    <table>
      <thead>
        <tr>
          <th scope="col">{columns[0]}</th>
          {columns.slice(1).map((column) => <th scope="col">{column}</th>)}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr>
            <th scope="row">{row.label}</th>
            {row.cells.map((cell) => <td>{cell}</td>)}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {note && <p>{note}</p>}
</section>
