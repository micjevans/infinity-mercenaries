---
type BulletCell = {
  intro?: string;
  bullets: string[];
};

type TableCell = string | number | BulletCell;

type TableRow = {
  label: string;
  cells: TableCell[];
};

interface Props {
  eyebrow?: string;
  title: string;
  columns: string[];
  rows: TableRow[];
  note?: string;
  variant?: "matrix" | "text";
  die?: string;
}

const {
  eyebrow = "Reference",
  title,
  columns,
  rows,
  note,
  variant = "matrix",
  die,
} = Astro.props;

const isBulletCell = (cell: TableCell): cell is BulletCell =>
  typeof cell === "object" && cell !== null && "bullets" in cell;
---

<section class:list={["rules-table-card", `variant-${variant}`]}>
  <header>
    <span>{eyebrow}</span>
    <strong>{title}</strong>
    {die && <span class="rules-table-die">{die}</span>}
  </header>
  <div class="rules-table-wrap">
    <table>
      <thead>
        <tr>
          <th scope="col">{columns[0]}</th>
          {columns.slice(1).map((column) => <th scope="col">{column}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => (
            <tr>
              <th scope="row">{row.label}</th>
              {row.cells.map((cell) => (
                <td>
                  {isBulletCell(cell) ? (
                    <>
                      {cell.intro && (
                        <p class="rules-table-cell-intro">{cell.intro}</p>
                      )}
                      <ul class="rules-table-bullets">
                        {cell.bullets.map((bullet) => (
                          <li>{bullet}</li>
                        ))}
                      </ul>
                    </>
                  ) : (
                    cell
                  )}
                </td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
  {note && <p>{note}</p>}
</section>
