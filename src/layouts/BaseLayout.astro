---
import "../styles/global.css";
import GoogleAuthButton from "../components/GoogleAuthButton";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Infinity: Mercenaries",
  description = "A narrative campaign framework for Infinity N5 mercenary companies.",
} = Astro.props;

const pageTitle =
  title === "Infinity: Mercenaries"
    ? title
    : `${title} | Infinity: Mercenaries`;

const googleClientId =
  import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || "YOUR_GOOGLE_CLIENT_ID";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/images/m2-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script src="https://apis.google.com/js/api.js" async defer></script>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a class="brand" href="/">
          <img
            class="brand-mark"
            src="/images/m2-logo.png"
            alt=""
            aria-hidden="true"
          />
          <span>Infinity: Mercenaries</span>
        </a>
        <div class="nav-links">
          <a href="/rules/">Rules</a>
          <a href="/contracts/">Contracts</a>
          <a href="/companies/">Companies</a>
          <a href="/events/">Events</a>
          <a href="/#campaign">Campaign</a>
          <a href="/#tutorial">Tutorial</a>
          <a href="/#resources">Resources</a>
          <a
            href="https://discord.gg/QJyzrQZGvG"
            target="_blank"
            rel="noreferrer">Discord</a
          >
          <GoogleAuthButton client:load clientId={googleClientId} />
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <div class="footer-brand">
          <img src="/images/m2-logo.png" alt="" aria-hidden="true" />
          <strong>Infinity: Mercenaries</strong>
        </div>
        <p>A community-made campaign framework for Infinity N5.</p>
      </div>
      <p class="legal-note">
        Unofficial fan project. Infinity is owned by Corvus Belli.
      </p>
    </footer>
  </body>
</html>
