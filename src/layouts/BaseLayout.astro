---
import "../styles/index.css";
import GoogleAuthButton from "../components/GoogleAuthButton";

interface Props {
  title?: string;
  description?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
}

const {
  title = "Infinity: Mercenaries",
  description = "A narrative campaign framework for Infinity N5 mercenary companies.",
  hideHeader = false,
  hideFooter = false,
} = Astro.props;

const pageTitle =
  title === "Infinity: Mercenaries"
    ? title
    : `${title} | Infinity: Mercenaries`;

const googleClientId =
  import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || "YOUR_GOOGLE_CLIENT_ID";

const navItems = [
  { href: "/rules/", label: "Rules" },
  { href: "/contracts/", label: "Contracts" },
  { href: "/companies/", label: "Companies" },
  { href: "/events/", label: "Events" },
];

const currentPath = Astro.url.pathname;

function isCurrentNav(href: string) {
  if (href.includes("#")) return false;
  return currentPath === href || currentPath.startsWith(href);
}

const backplaneTraces = [
  ["trace-a", "M-160 160 H320 L480 320 H960 L1120 160 H1760"],
  ["trace-b", "M1760 480 H1280 L1120 640 H640 L480 480 H-160"],
  ["trace-c", "M-160 800 H160 L320 960 H800 L960 800 H1760"],
  ["trace-d", "M1760 1120 H1440 L1280 1280 H640 L480 1120 H-160"],
  ["trace-e", "M-160 1600 H320 L480 1760 H960 L1120 1600 H1760"],
  ["trace-f", "M1280 -160 V320 L1120 480 V960 L1280 1120 V2360"],
  ["trace-g", "M800 -160 V160 L640 320 V800 L800 960 V2360"],
  ["trace-h", "M320 -160 V640 L160 800 V1280 L320 1440 V2360"],
];

const backplaneNodes = [
  [320, 160, 2.2],
  [480, 320, 2.2],
  [960, 320, 2.2],
  [1120, 160, 2.4],
  [480, 560, 2.2],
  [640, 640, 2.2],
  [1120, 640, 2.2],
  [1280, 480, 2.3],
  [160, 800, 2.2],
  [320, 960, 2.3],
  [800, 960, 2.2],
  [960, 800, 2.3],
  [480, 1120, 2.2],
  [640, 1280, 2.2],
  [1280, 1280, 2.2],
  [1440, 1120, 2.3],
  [320, 1600, 2.2],
  [480, 1760, 2.2],
  [960, 1760, 2.2],
  [1120, 1600, 2.3],
  [1280, 320, 2.2],
  [1120, 480, 2.2],
  [1280, 800, 2.2],
  [1280, 1120, 2.3],
  [800, 160, 2.2],
  [640, 320, 2.2],
  [800, 800, 2.2],
  [800, 960, 2.3],
  [320, 640, 2.2],
  [160, 800, 2.2],
  [320, 1440, 2.3],
];

const backplanePackets = [
  ["trace-a", 3.1, "8.4s", "-1.2s"],
  ["trace-b", 2.8, "10.2s", "-4.1s"],
  ["trace-d", 3, "9.4s", "-2.6s"],
  ["trace-e", 2.8, "11.8s", "-7.4s"],
  ["trace-f", 2.7, "9.8s", "-3.3s"],
  ["trace-g", 2.7, "10.8s", "-6.2s"],
];

const tracePathById = new Map(backplaneTraces.map(([id, d]) => [id, d]));

function toSeconds(value: string | number) {
  return Number(String(value).replace("s", ""));
}

function offsetSignalBegin(
  begin: string | number,
  dur: string | number,
  ratio: number,
) {
  return `${toSeconds(begin) - toSeconds(dur) * ratio}s`;
}

function signalTraceRatio(index: number) {
  const childIndex = index + 1;
  if (childIndex % 3 === 0) return 0.16;
  if (childIndex % 2 === 0) return 0.12;
  return 0.14;
}

const backplaneGridX = Array.from({ length: 11 }, (_, index) => index * 160);
const backplaneGridY = Array.from({ length: 15 }, (_, index) => index * 160);
const backplaneGridDots = backplaneGridY.flatMap((cy) =>
  backplaneGridX.map((cx) => [cx, cy]),
);

const backplaneTiles = Array.from({ length: 5 }, (_, index) => index);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/images/m2-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;500;600;700;800;900&family=Orbitron:wght@500;600;700;800&family=Share+Tech+Mono&display=swap"
      rel="stylesheet"
    />
    <script src="https://apis.google.com/js/api.js" async defer></script>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <title>{pageTitle}</title>
  </head>
  <body class="theme-control-panel is-boot-preparing">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="mainframe-backplane" aria-hidden="true">
      {
        backplaneTiles.map((tile) => (
          <svg
            class="backplane-tile"
            viewBox="0 0 1600 2200"
            preserveAspectRatio="xMidYMin slice"
          >
            <defs>
              <filter id={`trace-glow-${tile}`}>
                <feGaussianBlur stdDeviation="2.4" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            </defs>
            <g class="backplane-grid">
              <g class="backplane-mesh">
                {backplaneGridX.map((x) => (
                  <line x1={x} y1="-160" x2={x} y2="2360" />
                ))}
                {backplaneGridY.map((y) => (
                  <line x1="-160" y1={y} x2="1760" y2={y} />
                ))}
                {backplaneGridDots.map(([cx, cy]) => (
                  <circle cx={cx} cy={cy} r="1.15" />
                ))}
              </g>
              {backplaneTraces.map(([id, d]) => (
                <path id={`${id}-${tile}`} d={d} />
              ))}
            </g>
            <g class="backplane-nodes">
              {backplaneNodes.map(([cx, cy, r]) => (
                <circle cx={cx} cy={cy} r={r} />
              ))}
            </g>
            <g
              class="backplane-signal-traces"
              filter={`url(#trace-glow-${tile})`}
            >
              {backplanePackets.map(([traceId, , dur, begin]) => (
                <path d={tracePathById.get(traceId)} pathLength="100">
                  <animate
                    attributeName="stroke-dashoffset"
                    from="0"
                    to="-100"
                    dur={dur}
                    begin={begin}
                    repeatCount="indefinite"
                  />
                </path>
              ))}
            </g>
            <g class="backplane-packets" filter={`url(#trace-glow-${tile})`}>
              {backplanePackets.map(([traceId, , dur, begin], index) => (
                <circle class="backplane-packet-lead" r="2.1">
                  <animateMotion
                    dur={dur}
                    repeatCount="indefinite"
                    begin={offsetSignalBegin(
                      begin,
                      dur,
                      signalTraceRatio(index),
                    )}
                  >
                    <mpath href={`#${traceId}-${tile}`} />
                  </animateMotion>
                </circle>
              ))}
              {backplanePackets.map(([traceId, r, dur, begin]) => (
                <circle r={r}>
                  <animateMotion
                    dur={dur}
                    repeatCount="indefinite"
                    begin={begin}
                  >
                    <mpath href={`#${traceId}-${tile}`} />
                  </animateMotion>
                </circle>
              ))}
            </g>
          </svg>
        ))
      }
    </div>
    {!hideHeader && <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a class="brand" href="/">
          <img
            class="brand-mark"
            src="/images/m2-logo.png"
            alt=""
            aria-hidden="true"
          />
          <span>Infinity: Mercenaries</span>
        </a>
        <div class="nav-links">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={{ "is-current": isCurrentNav(item.href) }}
                aria-current={isCurrentNav(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
          <a
            class="nav-discord-link"
            href="https://discord.gg/QJyzrQZGvG"
            target="_blank"
            rel="noreferrer"
            aria-label="Join the Infinity: Mercenaries Discord"
            title="Join Discord"
          >
            <svg
              width="1.5em"
              height="1.5em"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M5.5 16c5 2.5 8 2.5 13 0M15.5 17.5l1 2s4.171-1.328 5.5-3.5c0-1 .53-8.147-3-10.5-1.5-1-4-1.5-4-1.5l-1 2h-2"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
              <path
                d="M8.528 17.5l-1 2s-4.171-1.328-5.5-3.5c0-1-.53-8.147 3-10.5 1.5-1 4-1.5 4-1.5l1 2h2"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
              <path
                d="M8.5 14c-.828 0-1.5-.895-1.5-2s.672-2 1.5-2 1.5.895 1.5 2-.672 2-1.5 2zM15.5 14c-.828 0-1.5-.895-1.5-2s.672-2 1.5-2 1.5.895 1.5 2-.672 2-1.5 2z"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </a>
          <GoogleAuthButton client:load clientId={googleClientId} />
        </div>
      </nav>
    </header>}
    <main id="main">
      <slot />
    </main>
    {!hideFooter && <footer class="site-footer">
      <div>
        <div class="footer-brand">
          <img src="/images/m2-logo.png" alt="" aria-hidden="true" />
          <strong>Infinity: Mercenaries</strong>
        </div>
        <p>A community-made campaign framework for Infinity N5.</p>
      </div>
      <p class="legal-note">
        Unofficial fan project. Infinity is owned by Corvus Belli.
      </p>
    </footer>}

    <script>
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed", "is-booted");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: "0px 0px -6% 0px" },
      );

      const bootFrameSelector = [
        ".holo-frame",
        ".glass-panel",
        ".button",
        ".command-button",
        ".icon-button",
        ".custom-select-trigger",
        ".login-btn",
        ".logout-btn",
        ".index-list a",
        ".feature-band article",
        ".resource-links a",
        ".rules-table-card",
        ".procedure-card",
        ".reference-link-callout",
        ".rules-example-callout",
        ".warning-callout",
        ".market-card",
        ".perk-card",
        ".downtime-event-card",
        ".downtime-choice-card",
        ".company-type-card",
        ".company-type-section",
        ".npc-profile-card",
        ".rule-card",
        ".sponsor-card",
        ".terminal-panel",
        ".video-panel",
        ".resource-group",
        ".company-section-card",
        ".company-roster-panel",
        ".company-detail-panel",
        ".company-empty-state",
        ".company-wizard__panel",
        ".event-tool-panel",
        ".event-round-card",
        ".pairing-downtime-event-card",
        ".legacy-modal__panel",
      ].join(",");

      const bootTextSelector = [
        "main h1",
        "main h2",
        "main h3",
        "main h4",
        "main h5",
        "main h6",
        "main p",
        "main li",
        "main dt",
        "main dd",
        "main figcaption",
        "main blockquote",
        "main .eyebrow",
        "main .kicker",
      ].join(",");

      const bootImageSelector = [
        "main img:not([aria-hidden='true'])",
        "main picture:not([aria-hidden='true']) img:not([aria-hidden='true'])",
      ].join(",");

      function hasReadableText(element) {
        return Boolean(element.textContent && element.textContent.trim());
      }

      function isTypeableText(element) {
        if (!hasReadableText(element)) return false;
        if (
          element.closest(
            [
              "a",
              "button",
              "input",
              "select",
              "textarea",
              "summary",
              "label",
              "table",
              ".site-header",
              ".site-footer",
              ".rules-sidebar-inner",
              ".resource-links",
              ".signal-strip",
              ".button",
              ".command-button",
              ".icon-button",
              ".login-btn",
              ".logout-btn",
              ".panel-kicker",
              ".company-count",
              ".legacy-level-badge",
              ".legacy-trooper-type",
            ].join(","),
          )
        ) {
          return false;
        }
        return true;
      }

      function bootKeyFor(attribute) {
        return attribute
          .replace(/^data-/, "boot-")
          .replace(/-([a-z])/g, (_, letter) => letter.toUpperCase())
          .concat("Prepared");
      }

      function installBootOutline(element) {
        if (element.querySelector(":scope > .boot-outline")) return;
        const outline = document.createElement("span");
        outline.className = "boot-outline";
        outline.setAttribute("aria-hidden", "true");
        element.append(outline);
      }

      function collectTextNodes(element) {
        const walker = document.createTreeWalker(
          element,
          NodeFilter.SHOW_TEXT,
          {
            acceptNode(node) {
              if (!node.nodeValue || !node.nodeValue.trim()) {
                return NodeFilter.FILTER_REJECT;
              }
              const parent = node.parentElement;
              if (
                parent?.closest(
                  "script,style,svg,.boot-outline,[aria-hidden='true']",
                )
              ) {
                return NodeFilter.FILTER_REJECT;
              }
              return NodeFilter.FILTER_ACCEPT;
            },
          },
        );
        const nodes = [];
        while (walker.nextNode()) {
          nodes.push(walker.currentNode);
        }
        return nodes;
      }

      function typeElement(element) {
        if (prefersReducedMotion || element.dataset.bootTyped === "true")
          return;
        const textNodes = collectTextNodes(element);
        if (!textNodes.length) return;

        element.dataset.bootTyped = "true";
        element.classList.add("is-typing");
        const reservedRect = element.getBoundingClientRect();
        if (reservedRect.height > 0) {
          element.style.minHeight = `${reservedRect.height}px`;
        }
        if (reservedRect.width > 0) {
          element.style.minWidth = `${reservedRect.width}px`;
        }
        const originals = textNodes.map((node) => node.nodeValue || "");
        const totalCharacters = originals.reduce(
          (total, text) => total + text.length,
          0,
        );
        if (!totalCharacters) return;

        textNodes.forEach((node) => {
          node.nodeValue = "";
        });

        const charactersPerTick = Math.max(
          1,
          Math.ceil(totalCharacters / (element.matches("h1,h2,h3") ? 32 : 52)),
        );
        let visibleCharacters = 0;
        const tick = () => {
          visibleCharacters += charactersPerTick;
          let remaining = visibleCharacters;
          textNodes.forEach((node, index) => {
            const original = originals[index];
            const count = Math.max(0, Math.min(original.length, remaining));
            node.nodeValue = original.slice(0, count);
            remaining -= original.length;
          });
          if (visibleCharacters < totalCharacters) {
            window.setTimeout(tick, 16);
          } else {
            element.classList.remove("is-typing");
            element.classList.add("is-typed");
            element.style.minHeight = "";
            element.style.minWidth = "";
          }
        };

        window.setTimeout(
          tick,
          60 + Number(element.style.getPropertyValue("--boot-order") || 0) * 28,
        );
      }

      function prepareBootElement(element, attribute, index) {
        if (!(element instanceof HTMLElement)) return;
        const bootKey = bootKeyFor(attribute);
        if (element.dataset[bootKey] === "true") return;
        if (element.closest("[aria-hidden='true']")) return;
        element.dataset[bootKey] = "true";
        element.setAttribute(attribute, "");
        element.style.setProperty("--boot-order", String(Math.min(index, 18)));
        if (attribute === "data-boot-frame") {
          installBootOutline(element);
        }
        if (prefersReducedMotion) {
          element.classList.add("revealed", "is-booted");
          return;
        }
        revealObserver.observe(element);
      }

      function collectMatches(scope, selector) {
        const matches = [];
        if (scope instanceof HTMLElement && scope.matches(selector)) {
          matches.push(scope);
        }
        matches.push(...Array.from(scope.querySelectorAll(selector)));
        return matches;
      }

      function prepareBootSequence(root = document) {
        const scope =
          root instanceof HTMLElement || root instanceof Document
            ? root
            : document;

        collectMatches(scope, bootFrameSelector).forEach((element, index) =>
          prepareBootElement(element, "data-boot-frame", index),
        );

        collectMatches(scope, bootTextSelector)
          .filter(isTypeableText)
          .forEach((element, index) =>
            prepareBootElement(element, "data-boot-text", index),
          );

        collectMatches(scope, bootImageSelector).forEach((element, index) =>
          prepareBootElement(element, "data-boot-image", index),
        );

        collectMatches(scope, "[data-reveal], [data-stagger]").forEach(
          (element, index) => prepareBootElement(element, "data-reveal", index),
        );
      }

      prepareBootSequence();
      document.body.classList.remove("is-boot-preparing");

      document.addEventListener(
        "animationstart",
        (event) => {
          const element = event.target;
          if (
            element instanceof HTMLElement &&
            element.matches("[data-boot-text]") &&
            event.animationName === "boot-text-ready"
          ) {
            typeElement(element);
          }
        },
        true,
      );

      const bootMutationObserver = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (node instanceof HTMLElement) {
              prepareBootSequence(node);
            }
          });
        });
      });

      bootMutationObserver.observe(document.body, {
        childList: true,
        subtree: true,
      });
    </script>
  </body>
</html>
