---
import { getCollection } from "astro:content";
const contractEntries = await getCollection("contracts");
const contractNames = contractEntries
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .map((entry) => entry.data.title || entry.slug);
const contractOrbitChunks =
  contractNames.length > 10
    ? [
        contractNames.slice(0, Math.ceil(contractNames.length / 2)),
        contractNames.slice(Math.ceil(contractNames.length / 2)),
      ]
    : [contractNames];
const getOrbitNumberFromCharCount = (charCount) =>
  Math.min(
    24,
    Math.max(6, Math.ceil((charCount * 6.6 * 24) / (Math.PI * 380))),
  );
const outerChunkCount = contractOrbitChunks[0]?.length || 0;
const innerOrbitFrom =
  outerChunkCount > 0 ? `${180 / outerChunkCount}deg` : "0deg";
let lastOrbitNumber = 0;
const contractOrbitMeta = contractOrbitChunks.map((chunk, index) => {
  const longestItemLength = Math.max(...chunk.map((name) => name.length));
  const requiredLength = longestItemLength * chunk.length * 0.7;
  const computedOrbit = getOrbitNumberFromCharCount(requiredLength);
  const orbitNumber = lastOrbitNumber
    ? Math.max(computedOrbit, lastOrbitNumber + 1)
    : computedOrbit;
  lastOrbitNumber = orbitNumber;
  const fontSize = Math.max(0.1, Math.min(0.55, 2.8 / orbitNumber));
  const from = index === 1 ? innerOrbitFrom : "0deg";
  console.log("orbit-test: chunk", index, {
    chunkSize: chunk.length,
    longestItemLength,
    requiredLength,
    computedOrbit,
    orbitNumber,
    fontSize,
    from,
  });
  return { orbitNumber, fontSize, from, contracts: chunk };
});
const largestOrbitNumber = Math.max(
  4,
  ...contractOrbitMeta.map((meta) => meta.orbitNumber),
);
const gravitySpotSize = Math.ceil((largestOrbitNumber * 520) / 12);
console.log(
  "orbit-test: largestOrbitNumber",
  largestOrbitNumber,
  "gravitySpotSize",
  gravitySpotSize,
);
console.log("orbit-test: contractOrbitChunks", contractOrbitChunks);
console.log("orbit-test: contractOrbitMeta", contractOrbitMeta);
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Orbit quick start</title>
    <link rel="stylesheet" href="/orbit.css" />
    <script src="/orbit.js" defer></script>
    <style>
      :root {
        color-scheme: dark;
        background: #090c0b;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(
            circle at 20% 20%,
            rgba(71, 221, 228, 0.12),
            transparent 20%
          ),
          radial-gradient(
            circle at 80% 10%,
            rgba(56, 183, 164, 0.08),
            transparent 24%
          ),
          radial-gradient(
            circle at 55% 50%,
            rgba(38, 232, 255, 0.04),
            transparent 28%
          ),
          #090c0b;
        color: #d8f8ff;
        font-family: Inter, system-ui, sans-serif;
      }

      .bigbang {
        width: min(100%, 560px);
        margin: 0 auto;
        padding: 2rem 0;
      }

      .gravity-spot {
        position: relative;
        width: min(100%, 560px);
        aspect-ratio: 1 / 1;
        display: grid;
        place-items: center;
        border-radius: 50%;
        overflow: hidden;
        background: radial-gradient(
          circle at 50% 50%,
          rgba(11, 25, 30, 0.9),
          rgba(5, 10, 14, 0.96)
        );
        box-shadow: inset 0 0 120px rgba(0, 255, 255, 0.08);
      }

      .gravity-spot::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: radial-gradient(
          circle at 50% 50%,
          rgba(71, 221, 228, 0.08),
          transparent 45%
        );
        pointer-events: none;
      }

      .orbit-4.range-360.labels {
        --o-size-ratio: 1.4;
      }

      .satellite.at-center {
        width: 5.6rem;
        height: 5.6rem;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: radial-gradient(
          circle at 25% 20%,
          rgba(71, 221, 228, 0.16),
          rgba(8, 18, 26, 0.92)
        );
        color: #d8f8ff;
        font-weight: 700;
        box-shadow: inset 0 0 0 1px rgba(71, 221, 228, 0.16);
      }

      .orbit-4.labels {
        position: relative;
        font-size: 0.72rem;
      }

      .orbit-5.labels {
        position: relative;
        font-size: 0.54rem;
      }

      o-arc {
        --o-fill: rgba(35, 169, 183, 0.14);
        --o-stroke: rgba(71, 221, 228, 0.72);
        --o-stroke-width: 0.6;
        color: #c8f7ff;
        cursor: pointer;
        transition:
          filter 180ms ease,
          --o-fill 180ms ease,
          --o-stroke 180ms ease;
        filter: drop-shadow(0 0 18px rgba(71, 221, 228, 0.14));
      }

      o-arc:hover {
        --o-fill: rgba(71, 221, 228, 0.24);
        --o-stroke: rgba(114, 255, 255, 0.9);
        filter: drop-shadow(0 0 28px rgba(71, 221, 228, 0.32));
      }

      .orbit-4 > o-arc.control-1 {
        --o-fill: rgba(194, 143, 247, 0.18);
      }

      .orbit-4 > o-arc.control-2 {
        --o-fill: rgba(126, 199, 255, 0.18);
      }

      .orbit-4 > o-arc.control-3 {
        --o-fill: rgba(255, 199, 110, 0.18);
      }

      .orbit-4 > o-arc.control-4 {
        --o-fill: rgba(126, 213, 151, 0.18);
      }

      .orbit-4 > o-arc:hover,
      .orbit-5 > o-arc:hover {
        filter: drop-shadow(0 0 28px rgba(71, 221, 228, 0.32));
      }

      .orbit-5 > o-arc.control-1 {
        --o-fill: rgba(159, 122, 234, 0.18);
      }

      .orbit-5 > o-arc.control-2 {
        --o-fill: rgba(96, 165, 250, 0.18);
      }

      .orbit-5 > o-arc.control-3 {
        --o-fill: rgba(251, 191, 36, 0.18);
      }

      .orbit-5 > o-arc.control-4 {
        --o-fill: rgba(52, 211, 153, 0.18);
      }

      .orbit-5 > o-arc.control-5 {
        --o-fill: rgba(244, 114, 182, 0.18);
      }
    </style>
  </head>
  <body>
    <div class="bigbang" style={`width: min(100%, ${gravitySpotSize}px);`}>
      <div
        class="gravity-spot"
        style={`width: ${gravitySpotSize}px; height: ${gravitySpotSize}px;`}
      >
        <div class="orbit-0">
          <div class="satellite at-center">MENU</div>
        </div>

        <div class="orbit-4 range-360 labels" style="--o-gap: 8;">
          <o-arc
            class="control-1 gap-12"
            text-anchor="middle"
            style="dominant-baseline: middle;"
          >
            rules
          </o-arc>
          <o-arc
            class="control-2 gap-12"
            text-anchor="middle"
            style="dominant-baseline: middle;"
          >
            companies
          </o-arc>
          <o-arc
            class="control-3 gap-12"
            text-anchor="middle"
            style="dominant-baseline: middle;"
          >
            events
          </o-arc>
          <o-arc
            class="control-4 gap-12"
            text-anchor="middle"
            style="dominant-baseline: middle;"
          >
            contracts
          </o-arc>
        </div>
        {
          contractOrbitMeta.map((orbit, orbitIndex) => (
            <div
              key={orbitIndex}
              class={`orbit-${orbit.orbitNumber} range-360 labels contracts`}
              style={`--o-size-ratio: 1; --o-force-ratio: 1; --o-fixed-font-size: ${orbit.fontSize}rem; --o-from: ${orbit.from}; --o-gap: 2;`}
            >
              {orbit.contracts.map((contract, index) => (
                <o-arc
                  key={index}
                  class={`control-${(index % 5) + 1} gap-10`}
                  text-anchor="middle"
                  style="dominant-baseline: middle;"
                >
                  {contract}
                </o-arc>
              ))}
            </div>
          ))
        }
      </div>
    </div>
    <script>
      function updateFlipForOrbit(orbitContainer) {
        if (!orbitContainer) return;
        let stackAngle = 0;
        Array.from(orbitContainer.querySelectorAll("o-arc")).forEach((arc) => {
          const rawAngle = getComputedStyle(arc).getPropertyValue("--o-angle");
          const arcAngle = arc.calcularExpresionCSS
            ? arc.calcularExpresionCSS(rawAngle)
            : parseFloat(rawAngle) || 0;
          const centerAngle = (((stackAngle + arcAngle / 2) % 360) + 360) % 360;
          const isBottomHalf = centerAngle >= 90 && centerAngle <= 270;

          if (isBottomHalf) {
            arc.setAttribute("flip", "");
          } else {
            arc.removeAttribute("flip");
          }
          stackAngle += arcAngle;
        });
      }

      window.addEventListener("load", () => {
        requestAnimationFrame(() => {
          document
            .querySelectorAll(".range-360.labels")
            .forEach((orbitContainer) => {
              updateFlipForOrbit(orbitContainer);
            });
        });
      });
    </script>
  </body>
</html>
