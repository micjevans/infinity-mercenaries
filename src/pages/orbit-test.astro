---
import BaseLayout from "../layouts/BaseLayout.astro";
import "@zumer/orbit/style";

const menuItems = [
  {
    id: "rules",
    label: "Rules",
    kicker: "Field Manual",
    href: "/rules/",
    icon: "R",
    description: "Campaign procedures, downtime, injuries, equipment, and season structure.",
  },
  {
    id: "contracts",
    label: "Contracts",
    kicker: "Mission Archive",
    href: "/contracts/",
    icon: "C",
    description: "Scenario files, objectives, deployment rules, twists, and rewards.",
  },
  {
    id: "companies",
    label: "Companies",
    kicker: "Command Node",
    href: "/companies/",
    icon: "Co",
    description: "Company rosters, stored troopers, credits, renown, and campaign state.",
  },
  {
    id: "events",
    label: "Events",
    kicker: "Organizer Tools",
    href: "/events/",
    icon: "E",
    description: "Event workspaces, participants, rounds, pairings, and organizer flow.",
  },
];

const labelSegments = menuItems.map((item, index) => ({
  ...item,
  from: index * 90 + 28,
  range: 54,
  iconAngle: index * 90 + 45,
}));

const tickMarks = Array.from({ length: 60 });
const vectorSpokes = Array.from({ length: 12 });
---

<BaseLayout
  title="Orbit Mercnet Menu Test"
  description="A basic Infinity: Mercenaries navigation menu built from Orbit primitives."
  hideFooter
>
  <main class="zumerDemo" data-radial-menu>
    <section class="zumerDemoInner" aria-labelledby="orbit-menu-title">
      <div class="zumerDemoIntro">
        <p class="eyebrow">Orbit conversion pass</p>
        <h1 id="orbit-menu-title">Mercnet rotary nav</h1>
        <p>Rebuilt from the old hologram wheel using Orbit arcs, vectors, satellites, capsules, and radial text.</p>
      </div>

      <div class="zumerDemoStage">
        <div class="bigbang mercnetRadial" aria-label="Mercnet navigation orbit">
          <div class="gravity-spot theme-cyan mercnetRadialSpot">
            <div class="orbit-12 mercnetRadialTicks" aria-hidden="true">
              {tickMarks.map(() => <div class="vector outer-orbit shrink-10 mercnetTick"></div>)}
            </div>

            <div class="orbit-10 from-120 range-240 mercnetRadialFineTicks" aria-hidden="true">
              {tickMarks.slice(0, 36).map(() => <div class="vector outer-orbit shrink-8 mercnetFineTick"></div>)}
            </div>

            <div class="orbit-8 mercnetRadialSpokes" aria-hidden="true">
              {vectorSpokes.map(() => <div class="vector shrink-92 mercnetSpoke"></div>)}
            </div>

            <div class="orbit-12 range-92 from-178 mercnetOuterAccent" aria-hidden="true">
              <o-arc class="outer-orbit shrink-80"></o-arc>
              <div class="satellite mercnetPulseNode"></div>
            </div>

            <div class="orbit-10 from-315 mercnetOuterArc" aria-hidden="true">
              <o-arc value="28" class="inner-orbit shrink-72"></o-arc>
            </div>

            <div class="orbit-9 from-42 range-132 mercnetWideArc" aria-hidden="true">
              <o-arc class="outer-orbit shrink-62"></o-arc>
            </div>

            <div class="orbit-7 from-190 range-86 mercnetWideArc mercnetWideArc--secondary" aria-hidden="true">
              <o-arc class="grow-1x"></o-arc>
            </div>

            <div class="orbit-8 from-18 mercnetBrokenArc" aria-hidden="true">
              <o-arc class="shrink-64"></o-arc>
              <o-arc class="shrink-64"></o-arc>
              <o-arc class="shrink-64"></o-arc>
              <o-arc class="shrink-64"></o-arc>
            </div>

            <div class="orbit-6 mercnetControls">
              {
                menuItems.map((item, index) => (
                  <o-arc
                    class:list={[
                      "grow-1x",
                      "mercnetControlArc",
                      index === 0 && "is-selected",
                    ]}
                    data-menu-control={item.id}
                  ></o-arc>
                ))
              }
            </div>

            <div class="orbit-7 mercnetActiveRing" aria-hidden="true">
              {
                menuItems.map((item, index) => (
                  <o-arc
                    class:list={[
                      "inner-orbit",
                      "shrink-72",
                      "mercnetActiveArc",
                      index === 0 && "is-visible",
                    ]}
                    data-active-arc={item.id}
                  ></o-arc>
                ))
              }
            </div>

            {
              labelSegments.map((item, index) => (
                <div
                  class="orbit-10 mercnetLabelOrbit"
                  style={`--o-from: ${item.from}deg; --o-range: ${item.range}deg;`}
                >
                  <o-arc
                    class:list={[
                      "mercnetLabelArc",
                      index === 0 && "is-selected",
                    ]}
                    data-menu-label-node={item.id}
                  >
                    {item.label}
                  </o-arc>
                </div>
              ))
            }

            <div class="orbit-4 mercnetIconRing" aria-hidden="true">
              {
                labelSegments.map((item, index) => (
                  <div
                    class:list={[
                      "satellite",
                      "spin-lock",
                      "mercnetIconNode",
                      index === 0 && "is-selected",
                    ]}
                    style={`--o-angle-composite: calc(${item.iconAngle}deg - 90deg);`}
                    data-menu-icon={item.id}
                  >
                    <div class="capsule mercnetIconCapsule">
                      <span>{item.icon}</span>
                    </div>
                  </div>
                ))
              }
            </div>

            <div class="orbit-8 range-250 from-320 mercnetOrbitText" aria-hidden="true">
              <o-arc class="flip" fit-range="true">MERCNET // ROTARY SELECTOR // SIGNAL READY //</o-arc>
            </div>

            <div class="orbit-0 mercnetCore">
              <div class="satellite at-center">
                <div class="capsule mercnetCoreCapsule">
                  <img src="/images/m2-logo.png" alt="" />
                  <span>MERCNET</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <aside class="mercnetReadout" aria-live="polite">
          <p class="eyebrow" data-readout-kicker>{menuItems[0].kicker}</p>
          <h2 data-readout-label>{menuItems[0].label}</h2>
          <p data-readout-description>{menuItems[0].description}</p>
          <a class="mercnetCommand" href={menuItems[0].href} data-readout-link>Open node</a>
        </aside>
      </div>
    </section>

    <script type="application/json" data-menu-items>
      {JSON.stringify(menuItems)}
    </script>
  </main>

  <script>
    import "@zumer/orbit";

    const root = document.querySelector("[data-radial-menu]");

    if (root instanceof HTMLElement) {
      const data = root.querySelector("[data-menu-items]");
      const items = data?.textContent ? JSON.parse(data.textContent) : [];
      const controls = Array.from(root.querySelectorAll("[data-menu-control]"));
      const labels = Array.from(root.querySelectorAll("[data-menu-label-node]"));
      const icons = Array.from(root.querySelectorAll("[data-menu-icon]"));
      const activeArcs = Array.from(root.querySelectorAll("[data-active-arc]"));
      const readoutKicker = root.querySelector("[data-readout-kicker]");
      const readoutLabel = root.querySelector("[data-readout-label]");
      const readoutDescription = root.querySelector("[data-readout-description]");
      const readoutLink = root.querySelector("[data-readout-link]");
      let selectedId = items[0]?.id ?? "rules";

      function setSelected(id) {
        selectedId = id;
        const item = items.find((entry) => entry.id === id);

        controls.forEach((control) => {
          control.classList.toggle("is-selected", control.getAttribute("data-menu-control") === id);
        });
        labels.forEach((label) => {
          label.classList.toggle("is-selected", label.getAttribute("data-menu-label-node") === id);
        });
        icons.forEach((icon) => {
          icon.classList.toggle("is-selected", icon.getAttribute("data-menu-icon") === id);
        });
        activeArcs.forEach((arc) => {
          arc.classList.toggle("is-visible", arc.getAttribute("data-active-arc") === id);
        });

        if (!item) return;
        if (readoutKicker) readoutKicker.textContent = item.kicker;
        if (readoutLabel) readoutLabel.textContent = item.label;
        if (readoutDescription) readoutDescription.textContent = item.description;
        if (readoutLink instanceof HTMLAnchorElement) readoutLink.href = item.href;
      }

      controls.forEach((control) => {
        control.addEventListener("pointerenter", () => {
          const id = control.getAttribute("data-menu-control");
          if (id) setSelected(id);
        });
        control.addEventListener("mouseup", () => {
          const id = control.getAttribute("data-menu-control");
          const item = items.find((entry) => entry.id === id);
          if (item?.href) window.location.href = item.href;
        });
      });

      root.addEventListener("keydown", (event) => {
        if (!(event instanceof KeyboardEvent)) return;
        const currentIndex = items.findIndex((item) => item.id === selectedId);
        if (event.key === "ArrowRight" || event.key === "ArrowDown") {
          event.preventDefault();
          setSelected(items[(currentIndex + 1 + items.length) % items.length].id);
        }
        if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
          event.preventDefault();
          setSelected(items[(currentIndex - 1 + items.length) % items.length].id);
        }
        if (event.key === "Enter") {
          const item = items.find((entry) => entry.id === selectedId);
          if (item?.href) window.location.href = item.href;
        }
      });

      root.tabIndex = 0;
      setSelected(selectedId);
    }
  </script>
</BaseLayout>

<style>
  .zumerDemo {
    min-height: calc(100svh - var(--header-height));
    display: grid;
    place-items: center;
    padding: clamp(2.5rem, 6vh, 5rem) 1rem;
  }

  .zumerDemoInner {
    width: min(100%, 78rem);
  }

  .zumerDemoIntro {
    max-width: 25rem;
    margin-bottom: clamp(1rem, 2.5vw, 1.75rem);
  }

  .zumerDemoIntro h1 {
    margin: 0 0 0.35rem;
    font-size: clamp(1.45rem, 2.5vw, 2.45rem);
    line-height: 1;
  }

  .zumerDemoIntro p:not(.eyebrow) {
    max-width: 23rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .zumerDemoStage {
    position: relative;
    display: grid;
    grid-template-columns: minmax(34rem, 0.98fr) minmax(22rem, 0.82fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }

  .zumerDemoStage::before {
    content: "";
    position: absolute;
    left: min(43%, 31rem);
    right: min(34%, 25rem);
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 240, 255, 0.72), rgba(214, 255, 63, 0.42), transparent);
    box-shadow: 0 0 1rem rgba(0, 240, 255, 0.34);
    pointer-events: none;
  }

  .mercnetRadial {
    width: min(88vw, 46rem);
    height: min(88vw, 46rem);
    overflow: visible;
    justify-self: center;
    filter:
      drop-shadow(0 0 2.8rem rgba(0, 240, 255, 0.14))
      drop-shadow(0 0 5rem rgba(0, 240, 255, 0.06));
  }

  .mercnetRadialSpot {
    --o-force: clamp(36rem, 44vw, 44rem);
    perspective: 500px;
    transform-style: preserve-3d;
  }

  .mercnetRadial :global(.satellite),
  .mercnetRadial :global([class*="orbit"]) {
    border: none;
  }

  .mercnetRadial :global(.satellite) {
    background: transparent;
  }

  .mercnetRadialTicks,
  .mercnetRadialFineTicks,
  .mercnetRadialSpokes {
    opacity: 0.46;
  }

  .mercnetTick {
    width: 1px;
    height: 2.1rem;
    background: linear-gradient(180deg, rgba(0, 240, 255, 0.78), transparent);
  }

  .mercnetFineTick {
    width: 1px;
    height: 1.1rem;
    background: rgba(0, 240, 255, 0.28);
  }

  .mercnetSpoke {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 240, 255, 0.2), rgba(214, 255, 63, 0.18));
  }

  .mercnetOuterAccent o-arc,
  .mercnetWideArc o-arc {
    --o-fill: rgba(0, 240, 255, 0.2);
    --o-stroke: rgba(0, 240, 255, 0.58);
    --o-stroke-width: 1;
    filter: drop-shadow(0 0 0.75rem rgba(0, 240, 255, 0.3));
  }

  .mercnetPulseNode {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--arwes-lime);
    box-shadow:
      0 0 0.8rem rgba(214, 255, 63, 0.52),
      0 0 1.4rem rgba(0, 240, 255, 0.32);
  }

  .mercnetOuterArc o-arc {
    --o-fill: rgba(214, 255, 63, 0.18);
    --o-stroke: rgba(214, 255, 63, 0.42);
    --o-stroke-width: 1;
  }

  .mercnetWideArc--secondary o-arc {
    --o-fill: rgba(0, 240, 255, 0.12);
    --o-stroke: rgba(0, 240, 255, 0.34);
  }

  .mercnetBrokenArc o-arc {
    --o-fill: rgba(0, 240, 255, 0.12);
    --o-stroke: rgba(0, 240, 255, 0.36);
    --o-stroke-width: 1;
  }

  .mercnetControlArc {
    --o-fill: rgba(0, 240, 255, 0.035);
    --o-stroke: rgba(0, 240, 255, 0.24);
    --o-stroke-width: 1;
    cursor: pointer;
    filter: drop-shadow(0 0 0.4rem rgba(0, 240, 255, 0.08));
  }

  .mercnetControlArc:hover,
  .mercnetControlArc.is-selected {
    --o-fill: rgba(214, 255, 63, 0.12);
    --o-stroke: rgba(214, 255, 63, 0.8);
    filter:
      drop-shadow(0 0 0.4rem rgba(214, 255, 63, 0.32))
      drop-shadow(0 0 1.2rem rgba(0, 240, 255, 0.18));
  }

  .mercnetActiveArc {
    --o-fill: transparent;
    --o-stroke: transparent;
    --o-stroke-width: 2;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .mercnetActiveArc.is-visible {
    --o-fill: rgba(214, 255, 63, 0.1);
    --o-stroke: rgba(214, 255, 63, 0.8);
    opacity: 1;
    filter: drop-shadow(0 0 0.8rem rgba(214, 255, 63, 0.28));
  }

  .mercnetLabelOrbit {
    pointer-events: none;
  }

  .mercnetLabelArc {
    --o-fill: none;
    --o-stroke: rgba(0, 240, 255, 0.02);
    --o-stroke-width: 1;
    color: rgba(0, 240, 255, 0.82);
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    filter: drop-shadow(0 0 0.55rem rgba(0, 240, 255, 0.32));
  }

  .mercnetLabelArc.is-selected {
    color: var(--arwes-lime);
    filter:
      drop-shadow(0 0 0.4rem rgba(214, 255, 63, 0.42))
      drop-shadow(0 0 1rem rgba(0, 240, 255, 0.28));
  }

  .mercnetIconNode {
    --o-size-ratio: 1.25;
    pointer-events: none;
  }

  .mercnetIconCapsule {
    width: 3.3rem;
    height: 3.3rem;
    display: grid;
    place-items: center;
    border: 1px solid rgba(0, 240, 255, 0.34);
    border-radius: 50%;
    background: rgba(2, 15, 15, 0.78);
    color: rgba(0, 240, 255, 0.86);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 900;
    box-shadow:
      inset 0 0 1rem rgba(0, 240, 255, 0.05),
      0 0 1rem rgba(0, 240, 255, 0.08);
  }

  .mercnetIconNode.is-selected .mercnetIconCapsule {
    border-color: rgba(214, 255, 63, 0.8);
    color: var(--arwes-lime);
    box-shadow:
      inset 0 0 1rem rgba(214, 255, 63, 0.08),
      0 0 1rem rgba(214, 255, 63, 0.25);
  }

  .mercnetOrbitText o-arc {
    --o-fill: none;
    --o-stroke: transparent;
    color: rgba(0, 240, 255, 0.72);
    font-family: var(--font-display);
    font-size: 1.08rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    filter: drop-shadow(0 0 0.55rem rgba(0, 240, 255, 0.28));
  }

  .mercnetCoreCapsule {
    width: 8.7rem;
    height: 8.7rem;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 0.35rem;
    border: 1px solid rgba(0, 240, 255, 0.32);
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(0, 240, 255, 0.16), transparent 62%),
      rgba(2, 15, 15, 0.82);
    box-shadow:
      inset 0 0 2rem rgba(0, 240, 255, 0.08),
      0 0 2rem rgba(0, 240, 255, 0.16);
  }

  .mercnetCoreCapsule img {
    width: 4.1rem;
    filter:
      drop-shadow(0 0 0.55rem rgba(214, 255, 63, 0.48))
      drop-shadow(0 0 1.3rem rgba(0, 240, 255, 0.24));
  }

  .mercnetCoreCapsule span {
    color: var(--arwes-cyan-bright);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .mercnetReadout {
    min-height: 17rem;
    padding: clamp(1.3rem, 3vw, 2.2rem);
    border: 1px solid rgba(0, 240, 255, 0.2);
    background:
      radial-gradient(circle at 20% 0%, rgba(0, 240, 255, 0.12), transparent 14rem),
      rgba(2, 15, 15, 0.62);
    box-shadow: 0 1.25rem 3rem rgba(0, 0, 0, 0.22);
    clip-path: var(--hud-angle);
  }

  .mercnetReadout h2 {
    margin: 0 0 0.8rem;
    font-size: clamp(2.2rem, 4vw, 4.2rem);
    line-height: 0.94;
  }

  .mercnetReadout p:not(.eyebrow) {
    margin-bottom: 1.25rem;
    color: var(--muted);
  }

  .mercnetCommand {
    display: inline-grid;
    min-height: 2.65rem;
    place-items: center;
    padding: 0.68rem 1rem;
    border: 1px solid rgba(214, 255, 63, 0.72);
    background:
      linear-gradient(135deg, rgba(214, 255, 63, 0.14), transparent 56%),
      rgba(2, 15, 15, 0.66);
    color: var(--arwes-lime);
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    clip-path: polygon(0.45rem 0, 100% 0, 100% calc(100% - 0.45rem), calc(100% - 0.45rem) 100%, 0 100%, 0 0.45rem);
    box-shadow: 0 0 1rem rgba(214, 255, 63, 0.12);
  }

  .mercnetCommand:hover {
    background: var(--arwes-lime);
    color: #06100f;
    box-shadow: 0 0 1.4rem rgba(214, 255, 63, 0.24);
  }

  @media (max-width: 980px) {
    .zumerDemoStage {
      grid-template-columns: 1fr;
    }

    .zumerDemoStage::before {
      display: none;
    }

    .mercnetRadial {
      margin: 0 auto;
    }

    .mercnetReadout {
      width: min(100%, 36rem);
      justify-self: center;
    }
  }

  @media (max-width: 620px) {
    .mercnetRadialSpot {
      --o-force: clamp(27rem, 92vw, 34rem);
    }

    .mercnetLabelArc {
      font-size: 1.15rem;
    }

    .mercnetCoreCapsule {
      width: 6.6rem;
      height: 6.6rem;
    }

    .mercnetCoreCapsule img {
      width: 3.1rem;
    }
  }
</style>
