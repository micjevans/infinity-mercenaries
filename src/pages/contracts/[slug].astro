---
import { getCollection, render } from "astro:content";
import RulesShell from "../../components/RulesShell.astro";

export async function getStaticPaths() {
  const entries = await getCollection("contracts");
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id.replace(/\.mdx?$/, "");

const contractHeadings = [
  { depth: 2, slug: "mission-objectives", text: "Mission Objectives" },
  { depth: 2, slug: "forces-and-deployment", text: "Forces and Deployment" },
  { depth: 2, slug: "scenario-special-rules", text: "Scenario Special Rules" },
  { depth: 2, slug: "twist", text: "Twist" },
  { depth: 2, slug: "end-of-mission", text: "End of Mission" },
];
---

<RulesShell
  title={entry.data.title}
  description={entry.data.description}
  section={entry.data.contractType ?? "Contract"}
  currentPath={`/contracts/${slug}/`}
  headings={contractHeadings}
  mode="contracts"
>
  <Content />
</RulesShell>
